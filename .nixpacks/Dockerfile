FROM ghcr.io/railwayapp/nixpacks:ubuntu-1745885067

ENTRYPOINT ["/bin/bash", "-l", "-c"]
WORKDIR /app/


COPY .nixpacks/nixpkgs-ba913eda2df8eb72147259189d55932012df6301.nix .nixpacks/nixpkgs-ba913eda2df8eb72147259189d55932012df6301.nix
RUN nix-env -if .nixpacks/nixpkgs-ba913eda2df8eb72147259189d55932012df6301.nix && nix-collect-garbage -d
COPY .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix
RUN nix-env -if .nixpacks/nixpkgs-ffeebf0acf3ae8b29f8c7049cd911b9636efd7e7.nix && nix-collect-garbage -d

COPY .nixpacks/assets /assets/
ARG BUILDKIT_DOCKERFILE_CHECK CI DATA_DIR NIXPACKS_METADATA NIXPACKS_SPA_OUTPUT_DIR NODE_ENV NPM_CONFIG_PRODUCTION RAILWAY_ENVIRONMENT RAILWAY_ENVIRONMENT_ID RAILWAY_ENVIRONMENT_NAME RAILWAY_PRIVATE_DOMAIN RAILWAY_PROJECT_ID RAILWAY_PROJECT_NAME RAILWAY_PUBLIC_DOMAIN RAILWAY_SERVICE_BTIRADENTES_FISIOVET_URL RAILWAY_SERVICE_ID RAILWAY_SERVICE_NAME RAILWAY_SERVICE_REVIVER_PET_URL RAILWAY_STATIC_URL RAILWAY_VOLUME_ID RAILWAY_VOLUME_MOUNT_PATH RAILWAY_VOLUME_NAME
ENV BUILDKIT_DOCKERFILE_CHECK=$BUILDKIT_DOCKERFILE_CHECK CI=$CI DATA_DIR=$DATA_DIR NIXPACKS_METADATA=$NIXPACKS_METADATA NIXPACKS_SPA_OUTPUT_DIR=$NIXPACKS_SPA_OUTPUT_DIR NODE_ENV=$NODE_ENV NPM_CONFIG_PRODUCTION=$NPM_CONFIG_PRODUCTION RAILWAY_ENVIRONMENT=$RAILWAY_ENVIRONMENT RAILWAY_ENVIRONMENT_ID=$RAILWAY_ENVIRONMENT_ID RAILWAY_ENVIRONMENT_NAME=$RAILWAY_ENVIRONMENT_NAME RAILWAY_PRIVATE_DOMAIN=$RAILWAY_PRIVATE_DOMAIN RAILWAY_PROJECT_ID=$RAILWAY_PROJECT_ID RAILWAY_PROJECT_NAME=$RAILWAY_PROJECT_NAME RAILWAY_PUBLIC_DOMAIN=$RAILWAY_PUBLIC_DOMAIN RAILWAY_SERVICE_BTIRADENTES_FISIOVET_URL=$RAILWAY_SERVICE_BTIRADENTES_FISIOVET_URL RAILWAY_SERVICE_ID=$RAILWAY_SERVICE_ID RAILWAY_SERVICE_NAME=$RAILWAY_SERVICE_NAME RAILWAY_SERVICE_REVIVER_PET_URL=$RAILWAY_SERVICE_REVIVER_PET_URL RAILWAY_STATIC_URL=$RAILWAY_STATIC_URL RAILWAY_VOLUME_ID=$RAILWAY_VOLUME_ID RAILWAY_VOLUME_MOUNT_PATH=$RAILWAY_VOLUME_MOUNT_PATH RAILWAY_VOLUME_NAME=$RAILWAY_VOLUME_NAME

# setup phase
# noop

# caddy phase
COPY . /app/.
RUN  caddy fmt --overwrite /assets/Caddyfile

# install phase
ENV NIXPACKS_PATH=/app/node_modules/.bin:$NIXPACKS_PATH
COPY . /app/.
RUN --mount=type=cache,id=s/e91188a4-7bae-4d18-8316-a6b028ed3fa8-/root/npm,target=/root/.npm npm i

# build phase
COPY . /app/.
RUN --mount=type=cache,id=s/e91188a4-7bae-4d18-8316-a6b028ed3fa8-node_modules/cache,target=/app/node_modules/.cache npm run build



RUN printf '\nPATH=/app/node_modules/.bin:$PATH' >> /root/.profile


# start
COPY . /app

CMD ["node server.js"]

